{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT h.spot_id, COUNT(*) as uses \n        FROM user_occupancy_history h \n        JOIN spots s ON s.id = h.spot_id\n        WHERE h.user_id = $1 AND s.status = 'free'\n        GROUP BY h.spot_id\n        ORDER BY uses DESC\n        LIMIT 1\n        ",
